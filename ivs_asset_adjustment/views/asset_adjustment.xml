<odoo>

    <record id="asset_adjustment_line_list_view" model="ir.ui.view">
        <field name="name">asset.adjustment.line.list.view</field>
        <field name="model">asset.adjustment.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="asset_location_id"/>
                <field name="asset_id"/>
                <field name="asset_code"/>
                <field name="different_asset_location_id"/>
                <field name="is_exist"/>
            </list>
        </field>
    </record>

    <record id="asset_adjustment_form_view" model="ir.ui.view">
        <field name="name">asset.adjustment.form.view</field>
        <field name="model">asset.adjustment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_start" type="object" string="Start"
                            class="oe_highlight"
                            invisible="state != 'draft'"/>

                    <button name="start_adjustment" type="object" string="Start Adjustment"
                            class="oe_highlight"
                            invisible="state != 'running'"/>

                    <button name="action_confirm" type="object" string="Confirm"
                            class="oe_highlight"
                            invisible="state != 'running'"/>

                    <button name="action_approve" type="object" string="Approve"
                            class="oe_highlight"
                            groups="ivs_asset_adjustment.asset_adjustment_manager"
                            invisible="state != 'confirm'"/>

                    <button name="action_set_to_draft" type="object" string="Reset"
                            invisible="state not in ('confirm','cancel')"/>

                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state != 'confirm'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,running,confirm"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <!-- attrs readonly => readonly expression -->
                            <field name="location_id" readonly="state in ('confirm','approve')"/>
                            <field name="method" readonly="state in ('confirm','approve')"/>
                        </group>
                        <group>
                            <field name="date" readonly="state in ('confirm','approve')"/>

                            <field name="company_id" invisible="1"/>
                            <field name="company_id"
                                   options="{'no_create': True}"
                                   groups="base.group_multi_company"
                                   readonly="state in ('confirm','approve')"/>

                            <field name="confirmed_user_id" invisible="1"/>
                            <field name="approved_user_id" invisible="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Assets">
                            <field name="line_ids"
                                   context="{'tree_view_ref': 'ivs_asset_adjustment.asset_adjustment_line_list_view'}"/>
                        </page>
                    </notebook>

                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" options="{'open_attachments': True}"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="asset_adjustment_list_view" model="ir.ui.view">
        <field name="name">asset.adjustment.list.view</field>
        <field name="model">asset.adjustment</field>
        <field name="arch" type="xml">
            <list sample="1">
                <field name="name"/>
                <field name="location_id"/>
                <field name="date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="asset_adjustment_search_view" model="ir.ui.view">
        <field name="name">asset.adjustment.search.view</field>
        <field name="model">asset.adjustment</field>
        <field name="arch" type="xml">
            <search>
                <!-- searchable fields -->
                <field name="name"/>
                <field name="location_id"/>
                <field name="state"/>

                <separator/>

                <!-- active / archived -->
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="archived" string="Archived" domain="[('active','=',False)]"/>

                <separator/>

                <!-- group by -->
                <filter name="group_by_location"
                        string="Location"
                        context="{'group_by': 'location_id'}"/>
            </search>
        </field>
    </record>

    <record id="asset_adjustment_view_action" model="ir.actions.act_window">
        <field name="name">Asset Adjustment</field>
        <field name="res_model">asset.adjustment</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Root Menu -->
       <menuitem id="menu_asset_adjustment_root"
          name="Asset Adjustment"
          action="asset_adjustment_view_action"
          sequence="102"/>

</odoo>


