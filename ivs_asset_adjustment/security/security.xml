<odoo>

    <!-- App Category (still ir.module.category) -->
    <record id="asset_adjustment_categ" model="ir.module.category">
        <field name="name">Asset Adjustment</field>
    </record>

    <!-- NEW in Odoo 19: privilege linked to the category -->
    <record id="asset_adjustment_privilege" model="res.groups.privilege">
        <field name="name">Asset Adjustment</field>
        <field name="category_id" ref="ivs_asset_adjustment.asset_adjustment_categ"/>
        <!-- sequence is optional -->
        <field name="sequence">10</field>
    </record>

    <!-- Groups now use privilege_id instead of category_id -->
    <record id="asset_adjustment_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="ivs_asset_adjustment.asset_adjustment_privilege"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="asset_adjustment_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="ivs_asset_adjustment.asset_adjustment_privilege"/>
        <field name="implied_ids" eval="[(4, ref('ivs_asset_adjustment.asset_adjustment_user'))]"/>
    </record>

    <record id="asset_adjustment_company_rule" model="ir.rule">
        <field name="name">Asset adjustment multi company rule</field>
        <field name="model_id" ref="model_asset_adjustment"/>
        <field eval="True" name="global"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>

</odoo>
